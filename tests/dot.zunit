#!/usr/bin/env zunit

@setup {
    DOTFILES=$PWD
    FAKE_HOME=$(mktemp -d)

    sed '/^case /,$d' "$DOTFILES/dot.sh" > "$FAKE_HOME/dot.sh"
    source "$FAKE_HOME/dot.sh"

    # Disable logging in tests
    _log() { :; }

    DIR="$DOTFILES"
    HOME="$FAKE_HOME"

    # zstat is consistent between platforms unlike stat
    zmodload zsh/stat
}

@teardown {
    rm -rf "$FAKE_HOME"
}

@test '_ensure creates directories, files, and permissions' {
    _ensure "$HOME/test-dir/"
    assert "$HOME/test-dir" is_dir

    _ensure "$HOME/test-parent/test-file"
    assert "$HOME/test-parent/test-file" is_file

    _ensure "$HOME/secret-dir/" 700
    assert "$HOME/secret-dir" is_dir
    assert "$(zstat -F "%A" +mode $HOME/secret-dir)" same_as "drwx------"
}

@test '_require fails when command is missing' {
    run _require "missing_cmd_$(date +%s)"
    assert $state equals 1
    assert "$output" contains "Error:"
}

@test '_require succeeds when command exists' {
    run _require zsh
    assert $state equals 0
}

@test 'init creates parent dirs, clones, and symlinks dot when target missing' {
    getpath="$FAKE_HOME/src"
    local target="$FAKE_HOME/src/github.com/arbourd/dotfiles"

    local git_args
    git() { git_args="$*"; }

    _init > /dev/null

    assert "$FAKE_HOME/src/github.com/arbourd" is_dir
    assert "$git_args" same_as "clone https://github.com/arbourd/dotfiles.git $target"
    assert "$HOME/.local/bin/dot" is_link
    assert "$(readlink "$HOME/.local/bin/dot")" same_as "$target/dot.sh"
}

@test 'init pulls and re-symlinks dot when target already exists' {
    local target="$FAKE_HOME/src/github.com/arbourd/dotfiles"
    mkdir -p "$target"
    getpath="$FAKE_HOME/src"

    local git_args
    git() { git_args="$*"; }

    _init > /dev/null

    assert "$git_args" same_as "-C $target pull"
    assert "$HOME/.local/bin/dot" is_link
    assert "$(readlink "$HOME/.local/bin/dot")" same_as "$target/dot.sh"
}

@test 'update reports up to date when HEAD does not change' {
    git() {
        if [[ "$*" == *"rev-parse --short HEAD" ]]; then echo "abc1234"; return 0; fi
        if [[ "$*" == *"pull --quiet" ]]; then return 0; fi
        command git "$@"
    }

    run _update

    assert $state equals 0
    assert "$output" contains "abc1234"
    assert "$output" contains "up to date"
}

@test 'update reports old and new hashes when HEAD changes' {
    local flag=$(mktemp)
    rm "$flag"
    git() {
        if [[ "$*" == *"pull --quiet" ]]; then touch "$flag"; return 0; fi
        if [[ "$*" == *"rev-parse --short HEAD" ]]; then
            if [[ -e "$flag" ]]; then echo "def5678"; else echo "abc1234"; fi
            return 0
        fi
        command git "$@"
    }

    run _update

    rm -f "$flag"
    assert $state equals 0
    assert "$output" contains "abc1234"
    assert "$output" contains "def5678"
}

@test 'link creates dotfile symlinks' {
    _link > /dev/null

    assert "$HOME/.bash_profile" is_link
    assert "$(readlink "$HOME/.bash_profile")" same_as "$DIR/sh/.shrc"
    assert "$HOME/.bashrc" is_link
    assert "$(readlink "$HOME/.bashrc")" same_as "$DIR/sh/.shrc"
    assert "$HOME/.zshrc" is_link
    assert "$(readlink "$HOME/.zshrc")" same_as "$DIR/sh/.shrc"
    assert "$HOME/.config/fish/config.fish" is_link
    assert "$(readlink "$HOME/.config/fish/config.fish")" same_as "$DIR/sh/config.fish"
    assert "$HOME/.config/fish/fish_plugins" is_link
    assert "$(readlink "$HOME/.config/fish/fish_plugins")" same_as "$DIR/sh/fish_plugins"
    assert "$HOME/.config/ghostty/config" is_link
    assert "$(readlink "$HOME/.config/ghostty/config")" same_as "$DIR/ghostty/config"
    assert "$HOME/.config/git/config" is_link
    assert "$(readlink "$HOME/.config/git/config")" same_as "$DIR/git/config"
    assert "$HOME/.config/git/gitignore" is_link
    assert "$(readlink "$HOME/.config/git/gitignore")" same_as "$DIR/git/gitignore"
    assert "$HOME/.gnupg/gpg-agent.conf" is_link
    assert "$(readlink "$HOME/.gnupg/gpg-agent.conf")" same_as "$DIR/gpg/gpg-agent.conf"
    assert "$HOME/.ssh/config" is_link
    assert "$(readlink "$HOME/.ssh/config")" same_as "$DIR/ssh/config"
    assert "$HOME/.vim/vimrc" is_link
    assert "$(readlink "$HOME/.vim/vimrc")" same_as "$DIR/vim/vimrc"
    assert "$HOME/.config/zed/settings.json" is_link
    assert "$(readlink "$HOME/.config/zed/settings.json")" same_as "$DIR/zed/settings.json"

    assert "$HOME/.gnupg" is_dir
    assert "$(zstat -F "%A" +mode $HOME/.gnupg)" same_as "drwx------"
    assert "$HOME/.config/fish/private.fish" is_file
    assert "$HOME/.config/git/private" is_file
}

@test 'link-agents creates agent symlinks with renaming' {
    mkdir -p "$FAKE_HOME/repo-mock/agents/skills/skill-a" \
             "$FAKE_HOME/repo-mock/agents/skills/skill-b" \
             "$FAKE_HOME/repo-mock/agents/personas"
    touch "$FAKE_HOME/repo-mock/agents/skills/skill-a/SKILL.md" \
          "$FAKE_HOME/repo-mock/agents/skills/skill-b/SKILL.md" \
          "$FAKE_HOME/repo-mock/agents/personas/helper.md" \
          "$FAKE_HOME/repo-mock/agents/personas/reviewer.md"

    DIR="$FAKE_HOME/repo-mock"
    _link_agents > /dev/null

    assert "$HOME/.claude/skills/skill-a" is_link
    assert "$HOME/.agents/skills/skill-a" is_link
    assert "$HOME/.claude/skills/skill-b" is_link
    assert "$HOME/.agents/skills/skill-b" is_link

    assert "$HOME/.claude/agents/helper.md" is_link
    assert "$(readlink "$HOME/.claude/agents/helper.md")" same_as "$FAKE_HOME/repo-mock/agents/personas/helper.md"
    assert "$HOME/.gemini/agents/helper.md" is_link
    assert "$HOME/.pi/agent/prompts/helper.md" is_link

    assert "$HOME/.copilot/agents/helper.agent.md" is_link
    assert "$(readlink "$HOME/.copilot/agents/helper.agent.md")" same_as "$FAKE_HOME/repo-mock/agents/personas/helper.md"
    assert "$HOME/.copilot/agents/reviewer.agent.md" is_link
    assert "$(readlink "$HOME/.copilot/agents/reviewer.agent.md")" same_as "$FAKE_HOME/repo-mock/agents/personas/reviewer.md"
}

@test '_remove_stale_link guards and removal' {
    touch "$HOME/real-file"
    _remove_stale_link "$HOME/real-file" "$DIR/"
    assert "$HOME/real-file" is_file

    ln -sf "$DIR/sh/.shrc" "$HOME/live-link"
    _remove_stale_link "$HOME/live-link" "$DIR/"
    assert "$HOME/live-link" is_link

    ln -sf "/etc/hosts" "$HOME/external-link"
    _remove_stale_link "$HOME/external-link" "$DIR/"
    assert "$HOME/external-link" is_link

    ln -sf "$DIR/nonexistent" "$HOME/stale-link"
    _remove_stale_link "$HOME/stale-link" "$DIR/"
    assert "$(readlink "$HOME/stale-link" 2>/dev/null)" is_empty
}

@test 'clean protects real files and unrelated symlinks' {
    _link > /dev/null

    touch "$HOME/.ssh/id_rsa"
    ln -sf /etc/hosts "$HOME/.ssh/external_link"
    ln -sf "$DIR/nonexistent" "$HOME/.ssh/stale_link"

    _clean > /dev/null

    assert "$HOME/.ssh/id_rsa" is_file
    assert "$HOME/.ssh/external_link" is_link
    assert "$(readlink "$HOME/.ssh/external_link")" same_as "/etc/hosts"
    assert "$(readlink "$HOME/.ssh/stale_link" 2>/dev/null)" is_empty
}

@test 'clean removes stale agent symlinks' {
    _link_agents > /dev/null

    ln -sf "$DIR/agents/skills/nonexistent" "$HOME/.claude/skills/stale-skill"
    ln -sf /etc/hosts "$HOME/.claude/skills/external-skill"

    _clean > /dev/null

    assert "$(readlink "$HOME/.claude/skills/stale-skill" 2>/dev/null)" is_empty
    assert "$HOME/.claude/skills/external-skill" is_link
}

@test 'handling paths with spaces' {
    SPACE_REPO="$FAKE_HOME/path with spaces"
    mkdir -p "$SPACE_REPO/sh"
    touch "$SPACE_REPO/sh/.shrc"

    DIR="$SPACE_REPO"
    _link > /dev/null

    assert "$HOME/.bash_profile" is_link
    assert "$(readlink "$HOME/.bash_profile")" same_as "$SPACE_REPO/sh/.shrc"
}

@test 'getpath resolution priority' {
    git() {
        if [[ "$*" == "config --global get.path" ]]; then
            echo "/from/git/config"
            return 0
        fi
        command git "$@"
    }

    unset getpath
    source "$FAKE_HOME/dot.sh"
    assert "$getpath" same_as "/from/git/config"

    unset getpath
    GETPATH="/from/env" source "$FAKE_HOME/dot.sh"
    assert "$getpath" same_as "/from/env"

    git() { return 1; }
    unset GETPATH
    unset getpath
    source "$FAKE_HOME/dot.sh"
    assert "$getpath" same_as "$HOME/src"
}

@test 'init symlink target is absolute when getpath contains a literal tilde' {
    GETPATH="~/src"
    getpath="$GETPATH"
    local target="$HOME/src/github.com/arbourd/dotfiles"

    local git_args
    git() { git_args="$*"; }

    _init > /dev/null

    assert "$HOME/.local/bin/dot" is_link
    assert "$(readlink "$HOME/.local/bin/dot")" same_as "$target/dot.sh"
}
