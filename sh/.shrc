## Exports
#
export EDITOR=vim                   # default editor
export GOPATH=$HOME/go              # go code home
export GPG_TTY=$(tty)               # gpg
export HOMEBREW_EDITOR=$EDITOR      # brew edit
export PATH=$GOPATH/bin:$PATH       # go bin
export PATH=$HOME/.cargo/bin:$PATH  # rust bin

## Initializations
#
if [ -e /opt/homebrew/bin/brew ]; then eval "$(/opt/homebrew/bin/brew shellenv)"; fi
if [ -e /opt/homebrew/bin/zoxide ]; then
    if [ -n "$ZSH_VERSION" ]; then eval "$(/opt/homebrew/bin/zoxide init zsh)"
    elif [ -n "$BASH_VERSION" ]; then eval "$(/opt/homebrew/bin/zoxide init bash)"; fi
fi

## Aliases
#
alias k="kubectl"
