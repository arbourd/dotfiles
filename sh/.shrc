## Exports
#
export EDITOR=vim
export PATH=$HOME/.local/bin:$PATH
export PATH=$HOME/go/bin:$PATH
export PATH=$HOME/.cargo/bin:$PATH
export PATH=/opt/homebrew/opt/rustup/bin:$PATH

## Initializations
#
if [ -n "${BASH_VERSION:-}" ]; then
    [[ -r "/opt/homebrew/etc/profile.d/bash_completion.sh" ]] && . "/opt/homebrew/etc/profile.d/bash_completion.sh"
fi

if [ -n "${ZSH_VERSION:-}" ]; then
    fpath=(~/.zsh/completions $fpath)
    autoload -Uz compinit
    if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
        compinit
    else
        compinit -C
    fi
fi

if [ -e /opt/homebrew/bin/brew ]; then eval "$(/opt/homebrew/bin/brew shellenv)"; fi

if [ -e /opt/homebrew/bin/zoxide ]; then
    if [ -n "${ZSH_VERSION:-}" ]; then eval "$(/opt/homebrew/bin/zoxide init zsh)"
    elif [ -n "${BASH_VERSION:-}" ]; then eval "$(/opt/homebrew/bin/zoxide init bash)"; fi
fi

## Aliases
#
alias k="kubectl"
